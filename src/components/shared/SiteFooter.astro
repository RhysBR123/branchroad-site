---
import { footer, footerCompanyLinks, footerContactLinks } from '../../data/site';
---
<footer>
  <div class="footer-grid">
    <div>
      <div class="footer-title">{footer.heading}</div>
      <p class="footer-copy">{footer.copy}</p>
    </div>
    <div>
      <div class="footer-col-label">Company</div>
      <div class="footer-links">
        {footerCompanyLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>
    <div>
      <div class="footer-col-label">Contact</div>
      <div class="footer-links">
        {footerContactLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>
  </div>
  <div class="footer-meta">
    <span>{footer.copyright}</span>
    <span>
      <a href={footer.privacyHref}>{footer.privacyLabel}</a> |
      <a href={footer.creditsHref}>{footer.creditsLabel}</a>
    </span>
  </div>
</footer>
