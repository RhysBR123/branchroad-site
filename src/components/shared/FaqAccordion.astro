---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  className?: string;
}

const { items, className = 'faq-grid' } = Astro.props;
---
<div class={className}>
  {items.map((item) => (
    <article class="faq-item">
      <button class="faq-question" type="button" data-faq-toggle>
        <span>{item.question}</span>
        <span class="icon" aria-hidden="true">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 14 14">
            <path d="M7 1v12M1 7h12"></path>
          </svg>
        </span>
      </button>
      <div class="faq-answer">
        <div class="faq-answer-inner">{item.answer}</div>
      </div>
    </article>
  ))}
</div>
