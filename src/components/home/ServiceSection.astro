---
import type { ServiceSectionData } from '../../data/home';

interface Props {
  service: ServiceSectionData;
}

const { service } = Astro.props;
const firstVideo = service.videos[0]?.src ?? '';
---
{service.theme === 'light' ? (
  <div class="section-light">
    <section class="section service-section" id={service.id}>
      <div class="section-label">{service.label}</div>
      <h2 class="section-title">
        {service.title} <em>{service.emphasis}</em>
      </h2>
      <div class="service-grid">
        <div class="service-content">
          {service.description.map((paragraph, index) => (
            <p class="service-description" style={index > 0 ? 'margin-top:16px' : ''}>{paragraph}</p>
          ))}
          {service.subtleLink && (
            <a href={service.subtleLink.href} class="service-link-subtle">{service.subtleLink.label}</a>
          )}
          <div class="service-features">
            {service.features.map((feature) => (
              <div class="service-feature">
                <span class="check" aria-hidden="true">
                  <svg viewBox="0 0 12 12"><path d="M2 6l3 3 5-5"></path></svg>
                </span>
                <span>{feature}</span>
              </div>
            ))}
          </div>
          <div class="testimonial">
            <p class="testimonial-text">{service.testimonial.quote}</p>
            <div class="testimonial-author">
              {service.testimonial.author} <span>-- {service.testimonial.company}</span>
            </div>
          </div>
        </div>
        <div class="service-sidebar">
          <div class="service-card" data-tilt>
            <div class="service-card-preview" data-lightbox-trigger style="position:relative;overflow:hidden">
              <video src={firstVideo} autoplay muted loop playsinline style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0"></video>
              <div class="play-btn" aria-hidden="true">
                <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
              </div>
            </div>
            <div class="service-card-switcher" data-video-switcher>
              {service.videos.map((video, index) => (
                <button
                  type="button"
                  class={index === 0 ? 'active' : ''}
                  data-video-src={video.src}
                  aria-pressed={index === 0 ? 'true' : 'false'}
                >
                  {video.label}
                </button>
              ))}
            </div>
            <div class="service-card-example-connected">
              <div class="service-card-label">Example project</div>
              <div class="service-card-example">{service.exampleText}</div>
            </div>
            <div class="service-card-body">
              <div class="service-card-pricing-box">
                <div class="service-pricing-intro">Service pricing</div>
                <div class="service-pricing"><span class="label">Starting from</span></div>
                <div class="service-pricing"><span class="price">{service.priceFrom}</span></div>
                <div class="price-note">{service.priceNote}</div>
              </div>
              <a href="#contact" class="service-cta">{service.cta}</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
) : (
  <section class="section service-section" id={service.id}>
    <div class="section-label">{service.label}</div>
    <h2 class="section-title">
      {service.title} <em>{service.emphasis}</em>
    </h2>
    <div class="service-grid">
      <div class="service-content">
        {service.description.map((paragraph, index) => (
          <p class="service-description" style={index > 0 ? 'margin-top:16px' : ''}>{paragraph}</p>
        ))}
        {service.subtleLink && (
          <a href={service.subtleLink.href} class="service-link-subtle">{service.subtleLink.label}</a>
        )}
        <div class="service-features">
          {service.features.map((feature) => (
            <div class="service-feature">
              <span class="check" aria-hidden="true">
                <svg viewBox="0 0 12 12"><path d="M2 6l3 3 5-5"></path></svg>
              </span>
              <span>{feature}</span>
            </div>
          ))}
        </div>
        <div class="testimonial">
          <p class="testimonial-text">{service.testimonial.quote}</p>
          <div class="testimonial-author">
            {service.testimonial.author} <span>-- {service.testimonial.company}</span>
          </div>
        </div>
      </div>
      <div class="service-sidebar">
        <div class="service-card" data-tilt>
          <div class="service-card-preview" data-lightbox-trigger style="position:relative;overflow:hidden">
            <video src={firstVideo} autoplay muted loop playsinline style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0"></video>
            <div class="play-btn" aria-hidden="true">
              <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
            </div>
          </div>
          <div class="service-card-switcher" data-video-switcher>
            {service.videos.map((video, index) => (
              <button
                type="button"
                class={index === 0 ? 'active' : ''}
                data-video-src={video.src}
                aria-pressed={index === 0 ? 'true' : 'false'}
              >
                {video.label}
              </button>
            ))}
          </div>
          <div class="service-card-example-connected">
            <div class="service-card-label">Example project</div>
            <div class="service-card-example">{service.exampleText}</div>
          </div>
          <div class="service-card-body">
            <div class="service-card-pricing-box">
              <div class="service-pricing-intro">Service pricing</div>
              <div class="service-pricing"><span class="label">Starting from</span></div>
              <div class="service-pricing"><span class="price">{service.priceFrom}</span></div>
              <div class="price-note">{service.priceNote}</div>
            </div>
            <a href="#contact" class="service-cta">{service.cta}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
)}
