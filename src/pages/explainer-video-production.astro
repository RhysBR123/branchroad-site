---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/shared/SiteNav.astro';
import SiteFooter from '../components/shared/SiteFooter.astro';
import FaqAccordion from '../components/shared/FaqAccordion.astro';
import GlobalScripts from '../components/shared/GlobalScripts.astro';
import { navLinks } from '../data/site';
import {
  explainerFaq,
  explainerHero,
  explainerTypes,
  faqSchema,
  processSteps,
  serviceSchema,
} from '../data/explainer';

import '../styles/site.css';
import '../styles/explainer.css';
---
<MarketingLayout
  title="Explainer Video Production for B2B Tech | Branch Road Media"
  description="Explainer video production for B2B tech companies. Live action and animated explainer video production to increase conversion, support sales enablement, and shorten sales cycles."
  ogTitle="Explainer Video Production for B2B Tech | Branch Road Media"
  ogDescription="Conversion-focused explainer video production for B2B tech teams. Strategy, scriptwriting, production, and campaign-ready versions."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <SiteNav links={navLinks} />

  <header class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="eyebrow">{explainerHero.eyebrow}</div>
        <h1>{explainerHero.title}</h1>
        <p class="hero-sub">{explainerHero.subtitle}</p>
      </div>

      <aside class="hero-card reveal">
        <div class="hero-media">
          <video src={explainerHero.exampleVideo} autoplay muted loop playsinline></video>
        </div>
        <div class="hero-card-body">
          <h2>Example explainer</h2>
          <p class="hero-card-copy">
            A reference clip showing the style, pace, and clarity we aim for in product explainers.
          </p>
          <div class="hero-example-tags">
            <span>Live action + graphics</span>
            <span>Campaign-ready versions</span>
          </div>
          <div class="hero-price-panel">
            <div class="hero-price-label">Process starting from</div>
            <div class="hero-price-value">£3,500</div>
            <p class="hero-price-copy">Scope, scripting, and delivery planning before production begins.</p>
          </div>
          <div class="hero-card-action">
            <a href="#contact" class="btn-primary">Let's talk explainers -></a>
          </div>
        </div>
      </aside>
    </div>
  </header>

  <main>
    <section class="block" id="types">
      <div class="container reveal">
        <div class="section-head">
          <div class="section-label">Flavours of explainers</div>
          <h2 class="section-title">An explainer for any occasion</h2>
        </div>
        <div class="grid-2">
          {explainerTypes.map((item) => (
            <article class="card">
              <div class="type-example">
                <video src={item.video} autoplay muted loop playsinline></video>
                <span class="type-example-label">{item.label}</span>
              </div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <div class="process-wrapper">
      <section class="block" id="process">
        <div class="container reveal">
          <div class="section-head">
            <div class="section-label">Our process</div>
            <h2 class="section-title">How we build explainer videos from <em>brief to delivery</em></h2>
          </div>
          <div class="process">
            {processSteps.map((step) => (
              <article class="step reveal">
                <div class="step-tag">{step.tag}</div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    </div>
  </main>

  <div class="container" id="contact">
    <section class="cta reveal" aria-label="Contact call to action">
      <h2>Ready to start your explainer?</h2>
      <p>Drop us your email and we will come back to you within 48 hours with next steps.</p>
      <div class="cta-actions">
        <div class="cta-actions-row">
          <input class="cta-email-input" type="email" name="email" placeholder="Your work email" aria-label="Your work email" />
          <a href="mailto:hello@branchroad.media?subject=Explainer%20Video%20Project%20Brief" class="btn-primary">Let us explain -></a>
        </div>
        <a href="/" class="btn-secondary">See other video services</a>
      </div>
    </section>
  </div>

  <div class="faq-wrapper">
    <section class="block" id="faq">
      <div class="container reveal">
        <div class="section-head">
          <div class="section-label">FAQs</div>
          <h2 class="section-title">Common questions about <em>explainer video production</em></h2>
        </div>
        <FaqAccordion items={explainerFaq} />
      </div>
    </section>
  </div>

  <SiteFooter />

  <GlobalScripts />
</MarketingLayout>
